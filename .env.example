# Copy to `.env` and fill in.
# Anthropic API key for the interview LLM.
ANTHROPIC_API_KEY=

# Optional: override the default model.
# CREWDEFINE_MODEL=claude-opus-4-7

# Optional: hard cap on total interview turns (defaults to 40).
# CREWDEFINE_MAX_TURNS=40

# Optional: log LLM request/response to this path for debugging (leave unset to disable).
# CREWDEFINE_DEBUG_LOG=
